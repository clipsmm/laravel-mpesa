{
    "name": "clipsmm/laravel-mpesa",
    "description": "Laravel Mpesa package",
    "keywords": [
        "laravel",
        "lumen",
        "mpesa"
    ],
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "authors": [
        {
            "name": "Cliff Mitamita",
            "email": "mitacliff@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/console": "^12.61.1|^13.12",
        "illuminate/http": "^12.61.1|^13.12",
        "illuminate/routing": "^12.61.1|^13.12",
        "illuminate/support": "^12.61.1|^13.12",
        "guzzlehttp/guzzle": "^7.12.1",
        "monolog/monolog": "^3.9"
    },
    "require-dev": {
        "mockery/mockery": "^1.6.12",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^10.5.62|^11.5.50|^12.5.8|^13.1"
    },
    "autoload": {
        "psr-4": {
            "LaravelMpesa\\": "src/",
            "LaravelMpesa\\Mocks\\": "tests/mocks"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "release": "php bin/release.php",
        "release:patch": "php bin/release.php patch",
        "release:minor": "php bin/release.php minor",
        "release:major": "php bin/release.php major"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "LaravelMpesa\\MpesaServiceProvider"
            ],
            "aliases": {
                "Mpesa": "LaravelMpesa\\Mpesa"
            }
        }
    }
}
